{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Site Analytics</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
    <div class="actions">
        <a href="/top" class="btn btn-secondary">Leaderboards</a>
        <a href="/relationships" class="btn btn-secondary">Relationships</a>
        <a href="/entities/services" class="btn btn-secondary">Other Services</a>
    </div>
</section>

{{#if cache_refresh_pending}}
<section class="cache-notice">
    <strong>Analytics cache is warming.</strong>
    <span>Refresh shortly for current rollups.</span>
</section>
{{/if}}

<section class="card">
    <div class="section-heading">
        <h2>Summary</h2>
        <span class="muted">{{total_hosts}} classified hosts</span>
    </div>
    <div class="stats-grid">
        {{#each metrics}}
        <article class="stat-item">
            <strong>{{value}}</strong>
            <span>{{label}}</span>
        </article>
        {{/each}}
    </div>
</section>

<div class="dashboard-grid dashboard-grid-wide analytics-grid">
    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Current Category Mix</h2>
                <span class="muted">Distribution of current host classifications from <code>site_profile</code>.</span>
            </div>
        </div>
        {{#if has_distribution}}
        <div class="chart-shell">
            <div class="chart-visual">
                {{{category_pie_svg}}}
            </div>
            <div class="chart-legend">
                {{#each category_legend}}
                <div class="legend-row">
                    <span class="legend-swatch" style="background: {{color}};"></span>
                    <div class="legend-copy">
                        <strong>{{label}}</strong>
                        <span class="muted">{{category}}</span>
                    </div>
                    <span class="count-pill">{{host_count}} {{count_label}}</span>
                    <span class="muted">{{percentage_label}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{else}}
        <p class="empty-copy">No classified hosts are available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Discovery Timeline</h2>
                <span class="muted">Daily histogram of newly classified hosts by category, based on <code>site_profile.created_at</code>.</span>
            </div>
        </div>
        {{#if has_timeline}}
        <div class="chart-scroll">
            {{{category_histogram_svg}}}
        </div>
        <p class="chart-note">Range: {{first_day}} to {{last_day}}</p>
        {{else}}
        <p class="empty-copy">No category timeline is available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Current Keyword Mix</h2>
                <span class="muted">Distribution of current <code>keyword:*</code> tags across known forum hosts.</span>
            </div>
        </div>
        {{#if has_keyword_distribution}}
        <div class="chart-shell">
            <div class="chart-visual">
                {{{keyword_pie_svg}}}
            </div>
            <div class="chart-legend">
                {{#each keyword_legend}}
                <div class="legend-row">
                    <span class="legend-swatch" style="background: {{color}};"></span>
                    <div class="legend-copy">
                        <strong>{{label}}</strong>
                        <span class="muted">{{category}}</span>
                    </div>
                    <span class="count-pill">{{host_count}} {{count_label}}</span>
                    <span class="muted">{{percentage_label}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{else}}
        <p class="empty-copy">No keyword-tagged forum hosts are available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Keyword Timeline</h2>
                <span class="muted">Daily histogram of when each <code>host + keyword</code> pair was first observed.</span>
            </div>
        </div>
        {{#if has_keyword_timeline}}
        <div class="chart-scroll">
            {{{keyword_histogram_svg}}}
        </div>
        <p class="chart-note">Range: {{keyword_first_day}} to {{keyword_last_day}}</p>
        {{else}}
        <p class="empty-copy">No keyword timeline is available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Current Language Mix</h2>
                <span class="muted">Distribution of page-level language detections, including declared metadata and text analysis.</span>
            </div>
        </div>
        {{#if has_language_distribution}}
        <div class="chart-shell">
            <div class="chart-visual">
                {{{language_pie_svg}}}
            </div>
            <div class="chart-legend">
                {{#each language_legend}}
                <div class="legend-row">
                    <span class="legend-swatch" style="background: {{color}};"></span>
                    <div class="legend-copy">
                        <strong>{{label}}</strong>
                        <span class="muted">{{category}}</span>
                    </div>
                    <span class="count-pill">{{host_count}} {{count_label}}</span>
                    <span class="muted">{{percentage_label}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{else}}
        <p class="empty-copy">No language detections are available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Current Topic Mix</h2>
                <span class="muted">Distribution of static page topic tags from local keyword, path, metadata, and heading rules.</span>
            </div>
        </div>
        {{#if has_topic_distribution}}
        <div class="chart-shell">
            <div class="chart-visual">
                {{{topic_pie_svg}}}
            </div>
            <div class="chart-legend">
                {{#each topic_legend}}
                <div class="legend-row">
                    <span class="legend-swatch" style="background: {{color}};"></span>
                    <div class="legend-copy">
                        <strong>{{label}}</strong>
                        <span class="muted">{{category}}</span>
                    </div>
                    <span class="count-pill">{{host_count}} {{count_label}}</span>
                    <span class="muted">{{percentage_label}}</span>
                </div>
                {{/each}}
            </div>
        </div>
        {{else}}
        <p class="empty-copy">No static topic tags are available yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>Topic Timeline</h2>
                <span class="muted">Daily histogram of when each <code>page + topic</code> pair was first observed.</span>
            </div>
        </div>
        {{#if has_topic_timeline}}
        <div class="chart-scroll">
            {{{topic_histogram_svg}}}
        </div>
        <p class="chart-note">Range: {{topic_first_day}} to {{topic_last_day}}</p>
        {{else}}
        <p class="empty-copy">No topic timeline is available yet.</p>
        {{/if}}
    </section>
</div>
{{/inline}}

{{> base}}
