{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Domain Blacklist</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
    <div class="actions">
        <a href="/api/blacklist" class="btn btn-secondary">JSON</a>
        <a href="/api/blacklist/auto" class="btn btn-secondary">Auto JSON</a>
    </div>
</section>

<section class="card">
    <div class="section-heading">
        <h2>Add Auto Rule</h2>
    </div>
    <form class="filter-form" action="/blacklist/auto" method="post">
        <input type="hidden" name="rule_type" value="{{category_rule_type}}">
        <select name="value" required>
            {{#each category_options}}
            <option value="{{value}}">{{label}}</option>
            {{/each}}
        </select>
        <input type="text" name="label" placeholder="label">
        <button class="btn" type="submit">Add Category</button>
    </form>
    <form class="filter-form stacked-form" action="/blacklist/auto" method="post">
        <input type="hidden" name="rule_type" value="{{keyword_rule_type}}">
        <input type="text" name="value" placeholder="keyword phrase" required>
        <input type="text" name="label" placeholder="label">
        <button class="btn" type="submit">Add Keyword</button>
    </form>
</section>

{{#if has_auto_rules}}
<section class="card">
    <div class="section-heading">
        <h2>Auto Rules</h2>
        <span class="muted">{{auto_rule_count}} rules</span>
    </div>
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Label</th>
                    <th>Added</th>
                    <th>State</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {{#each auto_rules}}
                <tr>
                    <td><span class="tag">{{rule_type}}</span></td>
                    <td><span class="row-link">{{value}}</span></td>
                    <td>{{label}}</td>
                    <td>{{created_at}}</td>
                    <td>
                        {{#if enabled}}
                        <span class="status-pill status-success">enabled</span>
                        {{else}}
                        <span class="status-pill status-suppressed">disabled</span>
                        {{/if}}
                    </td>
                    <td>
                        <div class="table-actions">
                            {{#if enabled}}
                            <form class="inline-form" action="/blacklist/auto/{{id}}/disable" method="post">
                                <button class="btn btn-secondary btn-compact" type="submit">Disable</button>
                            </form>
                            {{else}}
                            <form class="inline-form" action="/blacklist/auto/{{id}}/enable" method="post">
                                <button class="btn btn-secondary btn-compact" type="submit">Enable</button>
                            </form>
                            {{/if}}
                            <form class="inline-form" action="/blacklist/auto/{{id}}/delete" method="post">
                                <button class="btn btn-secondary btn-compact" type="submit">Remove</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</section>
{{else}}
<section class="empty-state">
    <h2>No auto blacklist rules</h2>
    <p>Add a category or keyword rule to blacklist matching scanned domains automatically.</p>
</section>
{{/if}}

{{#if has_auto_events}}
<section class="card">
    <div class="section-heading">
        <h2>Recent Auto Matches</h2>
    </div>
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Domain</th>
                    <th>Rule</th>
                    <th>Evidence</th>
                    <th>Page</th>
                    <th>Matched</th>
                </tr>
            </thead>
            <tbody>
                {{#each auto_events}}
                <tr>
                    <td>
                        <div class="table-cell-stack">
                            <span class="row-link">{{domain}}</span>
                            <span class="blacklist-badge">Auto Blacklisted</span>
                        </div>
                    </td>
                    <td>{{rule_type}} · {{matched_value}}</td>
                    <td>{{evidence}}</td>
                    <td>
                        {{#if source_page_id}}
                        <a href="/pages/{{source_page_id}}">Page #{{source_page_id}}</a>
                        {{else}}
                        <span class="muted">site profile</span>
                        {{/if}}
                    </td>
                    <td>{{created_at}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</section>
{{/if}}

<section class="card">
    <div class="section-heading">
        <h2>Manage From CLI</h2>
    </div>
    <div class="command-list">
        <code>cargo run --bin spyder -- blacklist list</code>
        <code>cargo run --bin spyder -- blacklist add example.com</code>
        <code>cargo run --bin spyder -- blacklist remove example.com</code>
        <code>cargo run --bin spyder -- blacklist auto list</code>
        <code>cargo run --bin spyder -- blacklist auto add-category market</code>
        <code>cargo run --bin spyder -- blacklist auto add-keyword "escrow required"</code>
        <code>cargo run --bin spyder -- blacklist auto apply-existing --dry-run</code>
    </div>
</section>

{{#if has_entries}}
<section class="card">
    <div class="section-heading">
        <h2>Configured Domains</h2>
        <span class="muted">{{entry_count}} rules</span>
    </div>
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Domain</th>
                    <th>Added</th>
                    <th>Current Page Links</th>
                    <th>Historical Scan Links</th>
                </tr>
            </thead>
            <tbody>
                {{#each entries}}
                <tr>
                    <td>
                        <div class="table-cell-stack">
                            <span class="row-link">{{domain}}</span>
                            <span class="blacklist-badge">Blacklisted</span>
                        </div>
                    </td>
                    <td>{{created_at}}</td>
                    <td><span class="count-pill">{{page_link_count}}</span></td>
                    <td><span class="count-pill">{{page_scan_link_count}}</span></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</section>
{{else}}
<section class="empty-state">
    <h2>No blacklisted domains</h2>
    <p>Add a domain from the CLI to stop discovered links from being queued while keeping them visible in page intelligence views.</p>
</section>
{{/if}}
{{/inline}}

{{> base}}
