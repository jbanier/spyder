{{#*inline "body"}}
<section class="hero">
    <p class="eyebrow">Dark Web Scan Intelligence</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
    <div class="actions">
        <a href="/pages" class="btn">Browse Pages</a>
        <a href="/work" class="btn btn-secondary">Inspect Queue</a>
        <a href="/relationships" class="btn btn-secondary">Site Relationships</a>
    </div>
</section>

<section class="card">
    <div class="section-heading">
        <h2>Scan Stats</h2>
        <a href="/api/stats" class="muted-link">JSON</a>
    </div>
    <div class="stats-grid">
        <article class="stat-item">
            <strong>{{stats.total_pages}}</strong>
            <span>Pages</span>
        </article>
        <article class="stat-item">
            <strong>{{stats.total_domains}}</strong>
            <span>Sites</span>
        </article>
        <article class="stat-item">
            <strong>{{stats.pending_work_units}}</strong>
            <span>Pending URLs</span>
        </article>
        <article class="stat-item">
            <strong>{{stats.failed_work_units}}</strong>
            <span>Failed URLs</span>
        </article>
        <article class="stat-item">
            <strong>{{stats.last_scrape}}</strong>
            <span>Last Scan</span>
        </article>
    </div>
</section>

<div class="dashboard-grid dashboard-grid-stacked">
    <section class="card">
        <div class="section-heading">
            <h2>Recent Pages</h2>
            <a href="/pages" class="muted-link">All pages</a>
        </div>
        {{#if has_pages}}
        <div class="compact-list">
            {{#each pages}}
            <a class="compact-row" href="/pages/{{id}}">
                <div class="table-cell-stack">
                    <span class="compact-title">{{title}}</span>
                    <span class="compact-meta">{{host}}</span>
                    {{#if site_category}}
                    <div class="inline-badges">
                        <span class="site-category-badge site-confidence-{{site_category.confidence}}">{{site_category.label}} · {{site_category.confidence}}</span>
                    </div>
                    {{/if}}
                </div>
                <span class="compact-meta">{{last_scanned_at}}</span>
            </a>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-copy">No pages have been scanned yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <h2>Shared Emails</h2>
            <a href="/entities/emails" class="muted-link">All emails</a>
        </div>
        {{#if has_email_entities}}
        <div class="compact-list">
            {{#each email_entities}}
            <a class="compact-row" href="{{detail_url}}">
                <span class="compact-title">{{value}}</span>
                <span class="count-pill">{{page_count}} pages</span>
            </a>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-copy">No email addresses detected yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <h2>Shared Wallets</h2>
            <a href="/entities/crypto" class="muted-link">All references</a>
        </div>
        {{#if has_crypto_entities}}
        <div class="compact-list">
            {{#each crypto_entities}}
            <a class="compact-row" href="{{detail_url}}">
                <span class="compact-title">{{asset_type}}</span>
                <span class="compact-meta">{{reference}}</span>
                <span class="count-pill">{{page_count}} pages</span>
            </a>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-copy">No crypto references detected yet.</p>
        {{/if}}
    </section>

    <section class="card">
        <div class="section-heading">
            <h2>Site Relationships</h2>
            <a href="/relationships" class="muted-link">All relationships</a>
        </div>
        {{#if has_relationships}}
        <div class="compact-list">
            {{#each relationships}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">{{source_host}}</span>
                    {{#if source_site_category}}
                    <div class="inline-badges">
                        <span class="site-category-badge site-confidence-{{source_site_category.confidence}}">{{source_site_category.label}} · {{source_site_category.confidence}}</span>
                    </div>
                    {{/if}}
                </div>
                <span class="relationship-arrow">→</span>
                <div class="table-cell-stack">
                    <span class="compact-meta">{{target_host}}</span>
                    {{#if target_site_category}}
                    <div class="inline-badges">
                        <span class="site-category-badge site-confidence-{{target_site_category.confidence}}">{{target_site_category.label}} · {{target_site_category.confidence}}</span>
                    </div>
                    {{/if}}
                    {{#if is_blacklisted}}
                    <div class="inline-badges">
                        <span class="blacklist-badge">Blacklisted</span>
                        <span class="muted">Matches {{blacklist_match_domain}}</span>
                    </div>
                    {{/if}}
                </div>
                <span class="count-pill">{{reference_count}} links</span>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-copy">No cross-site references have been observed yet.</p>
        {{/if}}
    </section>
</div>
{{/inline}}

{{> base}}
