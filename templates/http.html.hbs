{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Infrastructure Fingerprints</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
</section>

<div class="dashboard-grid dashboard-grid-wide dashboard-grid-stacked">
    <section class="card">
        <div class="section-heading">
            <h2>Observed Hosts</h2>
            <span class="muted">{{entity_count}} host endpoints</span>
        </div>
        {{#if has_entities}}
        <div class="compact-list">
            {{#each entities}}
            <a class="compact-row" href="{{detail_url}}">
                <div class="table-cell-stack">
                    <span class="compact-title">{{host}}</span>
                    <div class="inline-badges">
                        <span class="status-pill status-{{status}}">{{status}}</span>
                        {{#if http_status_code}}
                        <span class="count-pill">{{http_status_code}}</span>
                        {{/if}}
                        {{#if site_category}}
                        <span class="site-category-badge site-confidence-{{site_category.confidence}}">{{site_category.label}} · {{site_category.confidence}}</span>
                        {{/if}}
                    </div>
                    <span class="compact-meta">{{endpoint_url}}{{#if final_url}} -> {{final_url}}{{/if}}</span>
                    {{#if server_header}}
                    <span class="compact-meta">Server: {{server_header}}</span>
                    {{/if}}
                    {{#if stack_versions}}
                    <span class="compact-meta">Stack hints captured</span>
                    {{/if}}
                </div>
                <div class="table-cell-stack">
                    {{#if favicon_hash}}
                    <span class="compact-meta">Favicon {{favicon_hash}}</span>
                    {{/if}}
                    {{#if header_fingerprint}}
                    <span class="compact-meta">Headers {{header_fingerprint}}</span>
                    {{/if}}
                    {{#if last_success_at}}
                    <span class="compact-meta">Last success {{last_success_at}}</span>
                    {{/if}}
                </div>
            </a>
            {{/each}}
        </div>
        {{else}}
        <p class="empty-copy">No HTTP fingerprints have been captured yet. Run `spyder work` to populate this view.</p>
        {{/if}}
        {{#if has_pagination}}
        <section class="pagination-bar pagination-bar-inline">
            {{#if pagination.has_previous_page}}
            <a class="btn btn-secondary" href="{{pagination.previous_page_url}}">Previous</a>
            {{/if}}
            {{#if pagination.has_next_page}}
            <a class="btn btn-secondary" href="{{pagination.next_page_url}}">Next</a>
            {{/if}}
        </section>
        {{/if}}
    </section>

    <section class="card">
        {{#if has_selected}}
        <div class="section-heading">
            <h2>{{selected.host}}</h2>
            <div class="inline-badges">
                <span class="status-pill status-{{selected.status}}">{{selected.status}}</span>
                {{#if selected.http_status_code}}
                <span class="count-pill">{{selected.http_status_code}}</span>
                {{/if}}
                {{#if selected.site_category}}
                <span class="site-category-badge site-confidence-{{selected.site_category.confidence}}">{{selected.site_category.label}} · {{selected.site_category.confidence}}</span>
                {{/if}}
            </div>
        </div>
        <p class="detail-reference">{{selected.endpoint_url}}</p>
        {{#if selected.intel_leads}}
        <div class="inline-badges entity-leads">
            {{#each selected.intel_leads}}
            <a class="lead-badge severity-{{severity}}" href="{{detail_url}}">{{severity}} · {{rule_id}}</a>
            {{/each}}
        </div>
        {{/if}}
        {{#if selected.source_page_id}}
        <p class="detail-reference">
            Indexed page:
            <a class="inline-link" href="/pages/{{selected.source_page_id}}">{{selected.source_page_title}}</a>
        </p>
        {{/if}}
        <div class="metric-grid">
            {{#if selected.server_header}}
            <article class="metric-item">
                <span class="metric-label">Server</span>
                <strong>{{selected.server_header}}</strong>
            </article>
            {{/if}}
            {{#if selected.powered_by_header}}
            <article class="metric-item">
                <span class="metric-label">Powered By</span>
                <strong>{{selected.powered_by_header}}</strong>
            </article>
            {{/if}}
            {{#if selected.content_type_header}}
            <article class="metric-item">
                <span class="metric-label">Content Type</span>
                <strong>{{selected.content_type_header}}</strong>
            </article>
            {{/if}}
            {{#if selected.set_cookie_names}}
            <article class="metric-item">
                <span class="metric-label">Cookie Names</span>
                <strong>{{selected.set_cookie_names}}</strong>
            </article>
            {{/if}}
            {{#if selected.header_fingerprint}}
            <article class="metric-item">
                <span class="metric-label">Header Fingerprint</span>
                <strong>{{selected.header_fingerprint}}</strong>
            </article>
            {{/if}}
            {{#if selected.favicon_hash}}
            <article class="metric-item">
                <span class="metric-label">Favicon Hash</span>
                <strong>{{selected.favicon_hash}}</strong>
            </article>
            {{/if}}
        </div>

        <div class="compact-list">
            {{#if selected.final_url}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Final URL</span>
                    <span class="compact-meta">{{selected.final_url}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.favicon_url}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Favicon URL</span>
                    <span class="compact-meta">{{selected.favicon_url}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.location_header}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Location</span>
                    <span class="compact-meta">{{selected.location_header}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.via_header}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Via</span>
                    <span class="compact-meta">{{selected.via_header}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.alt_svc_header}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Alt-Svc</span>
                    <span class="compact-meta">{{selected.alt_svc_header}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.www_authenticate_header}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">WWW-Authenticate</span>
                    <span class="compact-meta">{{selected.www_authenticate_header}}</span>
                </div>
            </div>
            {{/if}}
            {{#if selected.last_error}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Last Error</span>
                    <span class="compact-meta">{{selected.last_error}}</span>
                </div>
            </div>
            {{/if}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Last Attempt</span>
                    <span class="compact-meta">{{selected.last_attempt_at}}</span>
                </div>
            </div>
            {{#if selected.last_success_at}}
            <div class="compact-row compact-row-static">
                <div class="table-cell-stack">
                    <span class="compact-title">Last Success</span>
                    <span class="compact-meta">{{selected.last_success_at}}</span>
                </div>
            </div>
            {{/if}}
        </div>

        {{#if selected.tls_observation}}
        <section class="card card-nested">
            <div class="section-heading">
                <h2>TLS</h2>
                <span class="status-pill status-{{selected.tls_observation.status}}">{{selected.tls_observation.status}}</span>
            </div>
            {{#if selected.tls_endpoint_url}}
            <p class="detail-reference">{{selected.tls_endpoint_url}}</p>
            {{/if}}
            <div class="compact-list">
                {{#if selected.tls_observation.certificate_sha256}}
                <div class="compact-row compact-row-static">
                    <div class="table-cell-stack">
                        <span class="compact-title">Certificate SHA-256</span>
                        <span class="tag">{{selected.tls_observation.certificate_sha256}}</span>
                    </div>
                </div>
                {{/if}}
                <div class="compact-row compact-row-static">
                    <div class="table-cell-stack">
                        <span class="compact-title">Last Attempt</span>
                        <span class="compact-meta">{{selected.tls_observation.last_attempt_at}}</span>
                    </div>
                </div>
                {{#if selected.tls_observation.last_success_at}}
                <div class="compact-row compact-row-static">
                    <div class="table-cell-stack">
                        <span class="compact-title">Last Success</span>
                        <span class="compact-meta">{{selected.tls_observation.last_success_at}}</span>
                    </div>
                </div>
                {{/if}}
                {{#if selected.tls_observation.last_error}}
                <div class="compact-row compact-row-static">
                    <div class="table-cell-stack">
                        <span class="compact-title">Last Error</span>
                        <span class="compact-meta">{{selected.tls_observation.last_error}}</span>
                    </div>
                </div>
                {{/if}}
            </div>
        </section>
        {{/if}}

        {{#if selected.stack_versions}}
        <section class="card card-nested">
            <div class="section-heading">
                <h2>Stack Versions</h2>
            </div>
            <pre class="detail-code-block">{{selected.stack_versions}}</pre>
        </section>
        {{/if}}

        {{#if selected.exposed_resources}}
        <section class="card card-nested">
            <div class="section-heading">
                <h2>Exposed Resources</h2>
            </div>
            <pre class="detail-code-block">{{selected.exposed_resources}}</pre>
        </section>
        {{/if}}

        {{#if selected.response_headers}}
        <section class="card card-nested">
            <div class="section-heading">
                <h2>Response Headers</h2>
            </div>
            <pre class="detail-code-block">{{selected.response_headers}}</pre>
        </section>
        {{/if}}
        {{else}}
        <div class="empty-state empty-state-inline">
            <h2>Select a host</h2>
            <p>Choose an observed HTTP endpoint from the left to inspect its headers, favicon hash, and any TLS fingerprint captured for the final HTTPS target.</p>
        </div>
        {{/if}}
    </section>
</div>
{{/inline}}

{{> base}}
