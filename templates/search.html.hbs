{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Search</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
</section>

<section class="card search-card">
    <form class="search-form" action="/search" method="get">
        <input
            class="search-field"
            type="text"
            name="query"
            value="{{query}}"
            placeholder="Title, URL, language, email, wallet"
        >
        <input
            class="search-limit"
            type="number"
            name="limit"
            min="1"
            max="50"
            value="{{limit}}"
        >
        <button type="submit" class="btn">Search</button>
    </form>
</section>

{{#if has_query}}
    {{#if has_results}}
    <section class="card">
        <div class="section-heading">
            <h2>Results</h2>
            <span class="muted">{{result_count}} matches</span>
        </div>
        <div class="search-results-grid">
            {{#each results}}
            <article class="search-result-card">
                <h3><a class="row-link" href="/pages/{{page_id}}">{{title}}</a></h3>
                <p><a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a></p>
                <div class="meta-strip">
                    <span><strong>Host:</strong> {{host}}</span>
                    <span><strong>Language:</strong> {{language}}</span>
                    <span><strong>Last Scan:</strong> {{scraped_at}}</span>
                </div>
                {{#if site_category}}
                <div class="meta-badges">
                    <span class="site-category-badge site-confidence-{{site_category.confidence}}">{{site_category.label}} · {{site_category.confidence}}</span>
                </div>
                {{/if}}
            </article>
            {{/each}}
        </div>
    </section>
    {{else}}
    <section class="empty-state">
        <h2>No results</h2>
        <p>No indexed page matched <strong>{{query}}</strong>.</p>
    </section>
    {{/if}}
{{else}}
<section class="empty-state">
    <h2>Search the dataset</h2>
    <p>Use the form above to search titles, URLs, languages, email addresses, and crypto references.</p>
</section>
{{/if}}
{{/inline}}

{{> base}}
