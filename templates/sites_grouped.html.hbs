{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Host Profiles</p>
    <h1>Sites Grouped by Title</h1>
    <p><a href="/sites">View All Sites</a></p>
    <p class="lead">Sites grouped by their page title. Multiple hosts with the same title often indicate mirrors, load balancers, or related infrastructure.</p>
</section>

{{#if groups}}
{{#each groups}}
<section class="card site-group-card">
    <div class="site-group-header" onclick="toggleGroup(this)">
        <div class="section-heading">
            <h2>
                <span class="expand-icon">▶</span>
                {{title}}
            </h2>
            <div class="inline-badges">
                <span class="count-badge">{{host_count}} hosts</span>
                <span class="count-badge">{{total_pages}} pages</span>
            </div>
        </div>
        <div class="meta-strip">
            <span><strong>Most recent scan:</strong> {{most_recent_scan}}</span>
        </div>
    </div>

    <div class="site-group-hosts" style="display: none;">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Host</th>
                        <th>Category</th>
                        <th>Pages</th>
                        <th>Last Scanned</th>
                        <th>Last Classified</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each hosts}}
                    <tr>
                        <td>{{host}}</td>
                        <td>
                            <span class="site-category-badge site-confidence-{{confidence}}">{{category}} · {{confidence}}</span>
                        </td>
                        <td><span class="count-pill">{{page_count}}</span></td>
                        <td>{{last_scanned_at}}</td>
                        <td>{{last_classified_at}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</section>
{{/each}}

{{#if has_pagination}}
<section class="pagination-bar">
    {{#if has_prev}}
    <a class="btn btn-secondary" href="/sites/grouped?limit={{limit}}&offset={{prev_offset}}">Previous</a>
    {{/if}}
    {{#if has_next}}
    <a class="btn btn-secondary" href="/sites/grouped?limit={{limit}}&offset={{next_offset}}">Next</a>
    {{/if}}
</section>
{{/if}}

{{else}}
<section class="empty-state">
    <h2>No grouped sites yet</h2>
    <p>Site profiles need titles to be grouped. Scan some pages and check back here.</p>
</section>
{{/if}}

<script>
function toggleGroup(header) {
    const card = header.closest('.site-group-card');
    const hostsDiv = card.querySelector('.site-group-hosts');
    const icon = header.querySelector('.expand-icon');

    if (hostsDiv.style.display === 'none') {
        hostsDiv.style.display = 'block';
        icon.textContent = '▼';
        card.classList.add('expanded');
    } else {
        hostsDiv.style.display = 'none';
        icon.textContent = '▶';
        card.classList.remove('expanded');
    }
}
</script>
{{/inline}}

{{> base}}
