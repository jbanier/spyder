{{#*inline "body"}}
<section class="hero hero-compact">
    <p class="eyebrow">Leaderboards</p>
    <h1>{{title}}</h1>
    <p class="lead">{{description}}</p>
</section>

{{#if has_sections}}
<div class="dashboard-grid dashboard-grid-stacked">
    {{#each sections}}
    <section class="card">
        <div class="section-heading">
            <div class="table-cell-stack">
                <h2>{{title}}</h2>
                <span class="muted">{{description}}</span>
            </div>
        </div>
        {{#if has_items}}
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Host</th>
                        <th>Category</th>
                        <th>Last Scan</th>
                        <th>{{count_label}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr>
                        <td>
                            <div class="table-cell-stack">
                                {{#if page_id}}
                                <a class="row-link" href="/pages/{{page_id}}">{{host}}</a>
                                {{else}}
                                <span>{{host}}</span>
                                {{/if}}
                                {{#if page_url}}
                                <div class="cell-subtitle">{{page_url}}</div>
                                {{/if}}
                            </div>
                        </td>
                        <td>
                            {{#if site_category}}
                            <span class="site-category-badge site-confidence-{{site_category.confidence}}">{{site_category.label}} · {{site_category.confidence}}</span>
                            {{else}}
                            <span class="muted">Unknown</span>
                            {{/if}}
                        </td>
                        <td>
                            {{#if last_scanned_at}}
                            {{last_scanned_at}}
                            {{else}}
                            <span class="muted">Never</span>
                            {{/if}}
                        </td>
                        <td><span class="count-pill">{{count}}</span></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <p class="empty-copy">No sites are ranked in this category yet.</p>
        {{/if}}
    </section>
    {{/each}}
</div>
{{else}}
<section class="empty-state">
    <h2>No site leaderboards yet</h2>
    <p>Run more scans and come back here to compare sites by extracted references and link activity.</p>
</section>
{{/if}}
{{/inline}}

{{> base}}
